# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_your_key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-side only (NOT prefixed with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# HubSpot (optional)
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=your-portal-id
HUBSPOT_ACCESS_TOKEN=pat-your-hubspot-token

# Backend API base URL — required for lead form submissions, calculators, AI chat
# Local: http://localhost:3030  ·  Prod (Supabase Edge): https://<project>.supabase.co/functions/v1/api
NEXT_PUBLIC_BACKEND_BASE_URL=http://localhost:3030

# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Marketing / retargeting pixels (all optional — each is a no-op without its ID)
# Preferred setup: configure GTM once below, then add the other 3 pixels INSIDE GTM.
# Standalone IDs below are kept as fallback if GTM is not desired.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=000000000000000
NEXT_PUBLIC_TIKTOK_PIXEL_ID=XXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=0000000

# rb2b — anonymous visitor identification (optional, paid)
NEXT_PUBLIC_REB2B_KEY=

# WhatsApp Business floating chat button (optional, no-op if unset)
# E.164 digits only — no +, spaces, or hyphens. Example: 14085380420 = +1 (408) 538-0420
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Anthropic AI (optional)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# App Environment
NEXT_PUBLIC_APP_ENV=development

# Public demo hub (optional)
NEXT_PUBLIC_DEMO_DASHBOARD_URL=https://demo.ondorealestate.com
NEXT_PUBLIC_DEMO_VIDEO_EMBED_URL=https://www.youtube.com/embed/your-demo-video-id
